# Environment variables for Neuro-Finance Pipeline
# Copy this file to .env and fill in your values

# OpenAI API (for script generation and analysis)
OPENAI_API_KEY=your_openai_api_key_here

# YouTube Data API (for comment/competitor analysis)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional: Anthropic API (alternative LLM)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: ElevenLabs API (for voice generation)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Twitter/X API (for trend analysis)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Pipeline configuration
OUTPUT_DIR=./output
TEMPLATES_DIR=./templates
MAX_IDEAS_PER_RUN=10
DEFAULT_VIDEO_DURATION=600
